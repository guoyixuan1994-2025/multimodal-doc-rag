# API 与 DeepSeek 配置
APP_API_KEY=replace-with-a-strong-random-key
LLM_API_KEY=replace-with-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=45

# 本地模型与输出目录
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
FASTEMBED_CACHE_DIR=.cache/fastembed
HF_CACHE_DIR=.cache/huggingface
MODELSCOPE_CACHE_DIR=.cache/modelscope
PROJECT_OUTPUT_DIR=data

# 检索参数
VECTOR_TOP_K=5
BM25_TOP_K=5
RERANK_TOP_N=3
MIN_RERANK_SCORE=0.2
CHUNK_SIZE=900
CHUNK_OVERLAP=150
MIN_CHUNK_CHARS=40
# MinerU 自动判断文本 PDF 或扫描件，并启用完整的结构化解析能力。
MINERU_CLI=mineru
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_FORMULA=true
MINERU_TABLE=true
MINERU_IMAGE_ANALYSIS=true
